# Local dashboard binding
APP_HOST=0.0.0.0
APP_PORT=8000

# When set, the local dashboard proxies API requests to the shared server instead of local Mongo/Redis.
# Example: http://211.188.52.76:8088
UPSTREAM_API_BASE_URL=

# Local MongoDB settings
MONGO_URI=mongodb://127.0.0.1:27017/mini_redis_demo
MONGO_DB_NAME=mini_redis_demo
MONGO_DATABASE=mini_redis_demo
MONGO_COLLECTION=products
SECRET_KEY=replace-with-a-random-secret

# Mini Redis server address
# When using a direct local connection, set the actual host here.
MINI_REDIS_HOST=127.0.0.1
MINI_REDIS_PORT=6379
MINI_REDIS_TIMEOUT=1.0
MINI_REDIS_BACKEND=tcp

DEMO_DEFAULT_KEY=customer:0001
BENCHMARK_DEFAULT_ITERATIONS=25
METRICS_HISTORY_LIMIT=50